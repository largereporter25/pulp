# Pulp — environment configuration
#
# Local development uses SQLite by default (no setup needed):
#   DATABASE_URL is optional; if unset, Pulp uses sqlite+aiosqlite:///./pulp.db
#
# For production on Vercel + Neon, set DATABASE_URL to your Neon connection
# string. The backend auto-rewrites postgresql:// -> postgresql+asyncpg://.
#
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=sqlite+aiosqlite:///./pulp.db
